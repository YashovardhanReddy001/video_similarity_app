# =====================================================
#  VidMatch — Configuration
# =====================================================
#
# COMPLETELY FREE OPTIONS (No credit card, ever):
# ─────────────────────────────────────────────────
#
# Option 1 — GROQ (RECOMMENDED — 1000 req/day free)
#   Sign up FREE at: https://console.groq.com
#   No credit card required. Just sign up and copy key.
GROQ_API_KEY=your_groq_api_key_here
#
# Option 2 — Google Gemini (1000 req/day free)
#   Get FREE key at: https://aistudio.google.com/apikey
#   No credit card required.
GEMINI_API_KEY=your_gemini_api_key_here
#
# ─────────────────────────────────────────────────
# PAID OPTIONS (Free credits on signup only):
# ─────────────────────────────────────────────────
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
#
# =====================================================
# Which provider to use: groq | gemini | openai | anthropic
AI_PROVIDER=groq
#
# Flask secret key (change to something random)
FLASK_SECRET_KEY=vidmatch-secret-key-change-me
#
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=104857600
